{
  "name": "accessibility-testing-suite",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/react-app",
    "apps/angular-app",
    "apps/vite-app",
    "packages/eslint-config-a11y"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test:a11y": "npm run test:shared && npm run test:a11y --workspaces --if-present",
    "test:shared": "tsx --test shared/rule-parser.test.ts",
    "lint:a11y": "npm run lint:a11y --workspaces --if-present",
    "rules:export": "tsx shared/rule-parser.ts rules tests/rule-index.json",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^9.9.0",
    "eslint": "^9.9.0",
    "husky": "^9.1.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
